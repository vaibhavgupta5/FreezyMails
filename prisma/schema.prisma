generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  avatarUrl        String?
  defaultAccountId String?
  createdAt        DateTime       @default(now())
  campaigns        Campaign[]
  emailAccounts    EmailAccount[]
  templates        Template[]
  suppressions     Suppression[]
  mailingLists     MailingList[]
}

model EmailAccount {
  id                String     @id @default(uuid())
  userId            String
  label             String
  fromName          String
  fromEmail         String
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPassEncrypted String?
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPassEncrypted String?
  isActive          Boolean    @default(true)
  healthScore       Int        @default(100)
  lastPollAt        DateTime?
  createdAt         DateTime   @default(now())
  accessToken       String?
  provider          String     @default("manual")
  refreshToken      String?
  tokenExpiresAt    DateTime?
  dailySentCount    Int        @default(0)
  dailySentResetAt  DateTime?
  warmupDay         Int        @default(1)
  isWarmupEnabled   Boolean    @default(false)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies           Reply[]
  campaigns         Campaign[] @relation("CampaignToEmailAccount")

  @@index([userId])
}

model Template {
  id                 String              @id @default(uuid())
  userId             String
  name               String
  subject            String
  body               String
  variables          Json
  attachments        Json                @default("[]")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  abTemplateVariants ABTemplateVariant[]
  campaigns          Campaign[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Campaign {
  id                      String              @id @default(uuid())
  userId                  String
  templateId              String
  name                    String
  status                  CampaignStatus      @default(DRAFT)
  scheduledAt             DateTime?
  abEnabled               Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  dailyLimit              Int?
  pacingType              String              @default("SLOW")
  bounceThreshold         Int                 @default(5)
  winnerSubjectVariantId  String?
  winnerTemplateVariantId String?
  abTemplateVariants      ABTemplateVariant[]
  template                Template            @relation(fields: [templateId], references: [id])
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  winnerSubjectVariant    ABSubjectVariant?   @relation("CampaignSubjectWinner", fields: [winnerSubjectVariantId], references: [id])
  winnerTemplateVariant   ABTemplateVariant?  @relation("CampaignTemplateWinner", fields: [winnerTemplateVariantId], references: [id])
  mailEvents              MailEvent[]
  recipients              Recipient[]
  replies                 Reply[]
  emailAccounts           EmailAccount[]      @relation("CampaignToEmailAccount")
  sequenceSteps           SequenceStep[]

  @@index([userId])
  @@index([status, scheduledAt])
}

model SequenceStep {
  id         String   @id @default(uuid())
  campaignId String
  stepIndex  Int
  delayDays  Int      @default(3)
  subject    String
  body       String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, stepIndex])
}

model Suppression {
  id        String   @id @default(uuid())
  userId    String
  email     String
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model Recipient {
  id          String          @id @default(uuid())
  campaignId  String
  email       String
  dynamicData Json
  status      RecipientStatus @default(PENDING)
  sentAt      DateTime?
  failReason  String?
  createdAt   DateTime        @default(now())
  mailEvents  MailEvent[]
  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  replies     Reply[]

  @@index([campaignId, status])
}

model MailEvent {
  id          String        @id @default(uuid())
  recipientId String
  campaignId  String
  type        MailEventType
  occurredAt  DateTime      @default(now())
  metadata    Json?
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient   Recipient     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([campaignId, type])
  @@index([recipientId, type])
}

model ABTemplateVariant {
  id              String             @id @default(uuid())
  templateId      String
  campaignId      String
  name            String
  body            String
  splitPercent    Int                @default(100)
  openCount       Int                @default(0)
  replyCount      Int                @default(0)
  firstReplyAt    DateTime?
  isWinner        Boolean            @default(false)
  subjectVariants ABSubjectVariant[]
  campaign        Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template        Template           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  wonCampaigns    Campaign[]         @relation("CampaignTemplateWinner")
}

model ABSubjectVariant {
  id                String            @id @default(uuid())
  templateVariantId String
  name              String
  subject           String
  splitPercent      Int               @default(100)
  openCount         Int               @default(0)
  replyCount        Int               @default(0)
  firstReplyAt      DateTime?
  isWinner          Boolean           @default(false)
  templateVariant   ABTemplateVariant @relation(fields: [templateVariantId], references: [id], onDelete: Cascade)
  wonCampaigns      Campaign[]        @relation("CampaignSubjectWinner")
}

model Reply {
  id             String         @id @default(uuid())
  campaignId     String
  recipientId    String
  emailAccountId String
  fromEmail      String
  subject        String
  body           String
  receivedAt     DateTime       @default(now())
  isRead         Boolean        @default(false)
  repliedAt      DateTime?
  isFlagged      Boolean        @default(false)
  classification ReplyCategory?
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emailAccount   EmailAccount   @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  recipient      Recipient      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([campaignId, receivedAt])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  DONE
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

enum MailEventType {
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

enum ReplyCategory {
  INTERESTED
  NOT_INTERESTED
  OUT_OF_OFFICE
  SPAM
  OTHER
}

model MailingList {
  id        String    @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  Contact[]

  @@index([userId])
}

model Contact {
  id            String      @id @default(uuid())
  mailingListId String
  email         String
  customFields  Json        @default("{}")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  mailingList   MailingList @relation(fields: [mailingListId], references: [id], onDelete: Cascade)

  @@unique([mailingListId, email])
  @@index([mailingListId])
}
